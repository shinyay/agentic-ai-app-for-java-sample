{
  "name": "VibeCode Studio - Java Development",
  "dockerComposeFile": "docker-compose.yml",
  "service": "app",
  "workspaceFolder": "/workspaces/agentic-ai-app-for-java-sample",

  "customizations": {
    "vscode": {
      "extensions": [
        "vscjava.vscode-java-pack",
        "vscjava.vscode-spring-initializr",
        "vscjava.vscode-spring-boot-dashboard",
        "vmware.vscode-spring-boot",
        "redhat.java",
        "vscjava.vscode-maven",
        "ms-vscode.vscode-json",
        "ms-azuretools.vscode-docker",
        "ms-azuretools.vscode-azurecli",
        "eamodio.gitlens",
        "ms-vscode.vscode-thunder-client",
        "ms-vscode.remote-repositories"
      ],
      "settings": {
        "java.configuration.runtimes": [
          {
            "name": "JavaSE-17",
            "path": "/usr/local/sdkman/candidates/java/current",
            "default": true
          }
        ],
        "java.compile.nullAnalysis.mode": "automatic",
        "java.jdt.ls.vmargs": "-XX:+UseParallelGC -XX:GCTimeRatio=4 -XX:AdaptiveSizePolicyWeight=90 -Dsun.zip.disableMemoryMapping=true -Xmx2G -Xms100m",
        "spring-boot.ls.checkUpdate": false,
        "files.exclude": {
          "**/target": true,
          "**/.classpath": true,
          "**/.project": true,
          "**/.settings": true,
          "**/.factorypath": true
        }
      }
    }
  },

  "forwardPorts": [8080, 5432],
  "portsAttributes": {
    "8080": {
      "label": "Spring Boot Application",
      "onAutoForward": "notify"
    },
    "5432": {
      "label": "PostgreSQL Database"
    }
  },

  "postCreateCommand": "bash .devcontainer/setup-mcp.sh && mvn clean compile",
  
  "remoteEnv": {
    "JAVA_HOME": "/usr/local/sdkman/candidates/java/current",
    "MAVEN_HOME": "/usr/local/sdkman/candidates/maven/current",
    "SPRING_PROFILES_ACTIVE": "dev",
    "NODE_PATH": "/usr/local/share/npm-global/lib/node_modules",
    "PATH": "${PATH}:/usr/local/share/npm-global/bin"
  },

  "remoteUser": "vscode"
}